anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_0xm2m")
stageNames = Array[String](["South Island", "Flying Carpet", "Aurora Icefield", "Mushroom Hill", "Canyon Cruise", "Casino Night", "Dynamite Plant", "Giant Wing", "Death Egg's Eye", "Hangar (Cutscene/Arcade)", "Hangar (Unused)", "Showcase Stage", "Mushroom Hill (Beta)", "South Island (Beta)", "Early Opening Cutscene", "Opening Cutscene (Final)"])
optionNames = Array[String](["Stage Data", "Brightness", "XY Position", "Texture/Palette", "Lighting Color", "Music/Level ID", "Background/Sky Color", "Floor Model", "Arena Platform Model", "Corner Pole models", "Extra Model", "Object Models", "Wall Models", "Stage Property", "Stage DSP", "Cloud Models", "Ring-Out Floor Height", "Wall Hitbox Height", "Arena Scale"])
mainMenuOptions = Array[String](["Edit a Stage!", "Export as .gerald", "Import from .gerald", "Set .gerald Directory", "Set ROM Directory"])
stagePreviewImages = Array[Texture2D]([ExtResource("5_lquwl"), ExtResource("3_getpj"), ExtResource("4_ryguw"), ExtResource("5_d13ii"), ExtResource("6_1u8w0"), ExtResource("7_0odxb"), ExtResource("8_lswn8"), ExtResource("9_a6jrf"), ExtResource("10_xuqvo"), ExtResource("11_1u8w0"), ExtResource("12_kq58d"), ExtResource("13_seu75"), ExtResource("14_htxhm"), ExtResource("15_jq2sk"), ExtResource("16_4k2k6"), ExtResource("17_0rl1p")])
descriptions = Array[String](["Miscellaneous stage settings. How to use it isn't documented yet to my knowledge...?", "Brightness of the whole stage.", "Stage_X and Stage_Y vectors. Affects lighting and shadows, I think?", "Set of textures and palettes for the stage to use.", "Lighting of the whole stage. Works like a \"multiply\" blend mode, so coloring this will make things darker.", "ID of the Music to use, presumably? idk", "Color that the stage is drawn on top of, usually the sky color.", "Model ID for the floor below the arena platform.", "Model ID for the platform you stand on.", "Model ID for the poles at the corners of the arena.", "Model ID for an object with unique properties, like South Island's bridge.", "Model IDs of the various decoration objects placed around the stage.", "Model IDs of the arena walls.", "Mysterious stage properties? Not thoroughly documented to my knowledge", "I'm gonna be so honest I have no idea what this one does", "Model IDs of the clouds in the sky, and other distant objects like one of Casino Night's blimps.", "Height at which characters will land when knocked over the walls when KOed.", "Hitbox height for the arena walls, for characters being knocked over it during KOs.", "Visual(?) scale of the arena platform."])

